{
  "name": "@thkruz/materialize",
  "description": "The responsive front-end library based on Material Design from Google.",
  "author": "The Materialize Team",
  "homepage": "https://github.com/thkruz/materialize#readme",
  "version": "3.0.0",
  "style": "dist/css/materialize.css",
  "sass": "sass/materialize.scss",
  "typings": "dist/js/materialize.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/js/materialize.js",
  "module": "./dist/js/materialize.mjs",
  "exports": {
    ".": {
      "import": "./dist/js/materialize.mjs",
      "require": "./dist/js/materialize.cjs.js"
    },
    "./dist/css/*": "./dist/css/*",
    "./sass/*": "./sass/*",
    "./components/*": "./components/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thkruz/materialize.git"
  },
  "bugs": {
    "url": "https://github.com/thkruz/materialize/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/materializecss"
    },
    {
      "type": "opencollective",
      "url": "https://opencollective.com/materialize"
    }
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc --noEmit -p tsconfig.spec.json",
    "pretest": "node build-specs.mts",
    "test": "jasmine-browser-runner runSpecs --config=jasmine.json",
    "build": "vite build && vite build --mode min && node build-css.mts",
    "build:release": "vite build && vite build --mode min && node build-css.mts --release",
    "release": "npm run lint && npm run build:release && node compress.mts",
    "prepublishOnly": "npm run release",
    "preversion": "npm run lint && npm test",
    "version": "npm run build:release && node compress.mts && git add .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "demo": "live-server",
    "vitest": "vitest",
    "test:unit": "vitest run"
  },
  "lint-staged": {
    "js/*.js": [
      "prettier --write",
      "git add"
    ]
  },
  "browserslist": [
    "last 2 versions",
    "Chrome >= 30",
    "Firefox >= 30",
    "Safari >= 8"
  ],
  "engine": "node >= 6",
  "dependencies": {
    "normalize.css": "^8.0.1"
  },
  "devDependencies": {
    "@fontsource/material-icons": "^5.2.5",
    "@microsoft/api-extractor": "^7.58.9",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/html-vite": "^10.4.6",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^20.5.2",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.10.0",
    "eslint-plugin-storybook": "^10.4.6",
    "jasmine": "^5.1.0",
    "jasmine-browser-runner": "^2.5.0",
    "jasmine-core": "^5.2.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "sass": "^1.77.8",
    "storybook": "^10.4.6",
    "tslib": "^2.6.3",
    "typescript": "^5.4.3",
    "typescript-eslint": "^8.6.0",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist/css",
    "dist/js",
    "sass/**/*.scss",
    "components",
    "LICENSE"
  ],
  "overrides": {
    "storybook": "$storybook"
  }
}
